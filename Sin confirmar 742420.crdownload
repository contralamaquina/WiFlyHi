<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Panel de Señal</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Big+Shoulders+Text:wght@500;700;900&display=swap');

  :root{
    --bg:#1a1815;
    --bg-panel:#221f1a;
    --bg-plate:#2a2620;
    --bevel-lo: #0f0d0b;
    --bevel-hi: #3a352c;
    --cream:#e8dcc4;
    --amber:#e0a84a;
    --amber-dim:#8a6a35;
    --teal:#4a9b8e;
    --teal-dim:#2c5c53;
    --red:#c1594d;
    --red-dim:#6e3229;
    --ink:#0f0d0b;
    --muted:#9c9182;
  }

  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(ellipse at 20% -10%, #262219 0%, transparent 55%),
      radial-gradient(ellipse at 100% 110%, #201d18 0%, transparent 50%),
      var(--bg);
    color:var(--cream);
    font-family:'IBM Plex Mono', monospace;
    min-height:100vh;
    padding:18px 14px 40px;
  }

  .wrap{max-width:640px; margin:0 auto;}

  header{
    display:flex; align-items:baseline; justify-content:space-between;
    padding:4px 4px 18px;
    border-bottom:1px solid #3a352c;
    margin-bottom:20px;
  }
  header h1{
    font-family:'Big Shoulders Text', sans-serif;
    font-weight:900;
    font-size:26px;
    letter-spacing:0.5px;
    margin:0;
    color:var(--cream);
    text-transform:uppercase;
  }
  header .sub{
    font-size:10px;
    color:var(--muted);
    letter-spacing:1.5px;
    text-transform:uppercase;
  }
  header .clock{
    font-size:11px;
    color:var(--amber);
    letter-spacing:1px;
  }

  .panel{
    background:linear-gradient(180deg, var(--bg-plate), var(--bg-panel));
    border-radius:10px;
    border:1px solid #3a352c;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.04),
      0 6px 16px rgba(0,0,0,0.35);
    padding:16px 16px 14px;
    margin-bottom:16px;
    position:relative;
  }
  .panel::before{
    content:'';
    position:absolute; top:8px; left:8px; width:5px; height:5px; border-radius:50%;
    background:var(--bevel-lo); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
  }
  .panel::after{
    content:'';
    position:absolute; top:8px; right:8px; width:5px; height:5px; border-radius:50%;
    background:var(--bevel-lo); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
  }

  .panel-head{
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:12px;
  }
  .panel-title{
    font-family:'Big Shoulders Text', sans-serif;
    font-weight:700;
    font-size:15px;
    letter-spacing:1.2px;
    text-transform:uppercase;
    color:var(--cream);
  }
  .panel-title .idx{
    color:var(--muted);
    font-family:'IBM Plex Mono', monospace;
    font-weight:500;
    font-size:11px;
    margin-right:8px;
  }

  .status-dot{
    width:9px; height:9px; border-radius:50%;
    display:inline-block;
    box-shadow:0 0 6px currentColor;
  }
  .status-dot.ok{color:var(--teal); background:var(--teal);}
  .status-dot.warn{color:var(--amber); background:var(--amber);}
  .status-dot.off{color:var(--red); background:var(--red);}
  .status-dot.idle{color:var(--muted); background:var(--muted); box-shadow:none;}

  .gauge-row{
    display:flex; align-items:center; gap:16px;
    margin-bottom:12px;
  }

  .bars{
    display:flex; align-items:flex-end; gap:3px; height:34px;
  }
  .bars .b{
    width:8px; background:var(--bevel-lo);
    border-radius:2px 2px 0 0;
    transition:background 0.4s ease;
  }
  .bars .b:nth-child(1){height:20%;}
  .bars .b:nth-child(2){height:40%;}
  .bars .b:nth-child(3){height:60%;}
  .bars .b:nth-child(4){height:80%;}
  .bars .b:nth-child(5){height:100%;}
  .bars .b.lit{background:var(--teal); box-shadow:0 0 6px var(--teal-dim);}
  .bars .b.lit.warn{background:var(--amber); box-shadow:0 0 6px var(--amber-dim);}
  .bars .b.lit.weak{background:var(--red); box-shadow:0 0 6px var(--red-dim);}

  .readout{
    flex:1;
    background:var(--ink);
    border-radius:6px;
    padding:8px 12px;
    box-shadow:inset 0 2px 4px rgba(0,0,0,0.5);
  }
  .readout .big{
    font-size:20px; font-weight:600; color:var(--amber);
    letter-spacing:0.5px;
  }
  .readout .lbl{
    font-size:9px; color:var(--muted); letter-spacing:1px; text-transform:uppercase;
  }

  .metrics{
    display:grid; grid-template-columns:repeat(3,1fr); gap:8px;
    margin-bottom:8px;
  }
  .metric{
    background:var(--ink);
    border-radius:6px; padding:7px 8px;
    box-shadow:inset 0 2px 4px rgba(0,0,0,0.5);
  }
  .metric .v{font-size:14px; color:var(--cream); font-weight:600;}
  .metric .k{font-size:8.5px; color:var(--muted); letter-spacing:0.8px; text-transform:uppercase; margin-top:2px;}

  .note{
    font-size:10.5px; color:var(--muted); line-height:1.5; margin-top:10px;
    border-top:1px dashed #3a352c; padding-top:8px;
  }
  .note b{color:var(--amber-dim);}

  button{
    font-family:'IBM Plex Mono', monospace;
    font-weight:600; font-size:11.5px; letter-spacing:0.8px; text-transform:uppercase;
    background:linear-gradient(180deg, #3a352c, #2a2620);
    color:var(--cream);
    border:1px solid #4a4436;
    border-radius:6px;
    padding:9px 14px;
    cursor:pointer;
    box-shadow:0 2px 0 var(--bevel-lo), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  button:active{transform:translateY(1px); box-shadow:0 1px 0 var(--bevel-lo);}
  button:disabled{opacity:0.4; cursor:not-allowed;}

  .device-list{margin-top:10px;}
  .device-card{
    background:var(--ink); border-radius:8px; padding:12px; margin-bottom:6px;
  }
  .device-card .name{color:var(--cream); font-size:13px; font-weight:600; margin-bottom:8px;}
  .device-card .rows{display:grid; grid-template-columns:1fr 1fr; gap:8px;}
  .device-card .field{background:var(--bg-plate); border-radius:6px; padding:6px 8px;}
  .device-card .field .v{font-size:13px; color:var(--teal); font-weight:600;}
  .device-card .field .v.warn{color:var(--amber);}
  .device-card .field .v.off{color:var(--muted); font-weight:400; font-size:11px;}
  .device-card .field .k{font-size:8.5px; color:var(--muted); letter-spacing:0.7px; text-transform:uppercase; margin-top:1px;}
  .battery-bar{height:5px; border-radius:3px; background:var(--bevel-lo); margin-top:5px; overflow:hidden;}
  .battery-bar .fill{height:100%; background:var(--teal); border-radius:3px;}
  .battery-bar .fill.low{background:var(--red);}
  .battery-bar .fill.mid{background:var(--amber);}

  .progress{
    height:8px; border-radius:4px; background:var(--ink);
    box-shadow:inset 0 2px 4px rgba(0,0,0,0.5);
    overflow:hidden; margin-top:6px;
  }
  .progress .fill{
    height:100%; width:0%; border-radius:4px;
    background:linear-gradient(90deg, var(--teal-dim), var(--teal));
    transition:width 0.15s linear;
  }
  .progress .fill.up{
    background:linear-gradient(90deg, var(--amber-dim), var(--amber));
  }
  /* ---------- CONSOLA CENTRAL (estilo nave espacial) ---------- */
  .console-panel{
    background:
      repeating-linear-gradient(115deg, rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px, transparent 1px, transparent 5px),
      linear-gradient(180deg, #24211b, #1c1a15);
  }
  .console-circle{
    position:relative;
    width:264px; height:264px;
    margin:14px auto 10px;
  }
  .console-ring{
    position:absolute; inset:0; border-radius:50%;
    border:1px dashed #3a352c;
  }
  .console-power{
    position:absolute; top:50%; left:50%;
    width:104px; height:104px; margin:-52px 0 0 -52px;
    border-radius:50%;
    background: radial-gradient(circle at 32% 28%, #3c362c 0%, #17140f 72%);
    border:2px solid #4a4436;
    box-shadow:
      0 8px 18px rgba(0,0,0,0.6),
      inset 0 2px 5px rgba(255,255,255,0.07),
      inset 0 -6px 10px rgba(0,0,0,0.4),
      0 0 0 6px #1a1815, 0 0 0 7px #4a4436;
    color:var(--amber);
    font-family:'Big Shoulders Text', sans-serif; font-weight:900;
    font-size:12px; letter-spacing:0.8px; text-transform:uppercase; line-height:1.2;
    cursor:pointer;
    display:flex; align-items:center; justify-content:center; text-align:center;
    padding:6px;
    transition:box-shadow 0.15s ease, filter 0.15s ease;
  }
  .console-power:active{ filter:brightness(0.85); }
  .console-power.engaged{
    color:var(--teal);
    box-shadow:
      0 8px 18px rgba(0,0,0,0.6),
      inset 0 2px 5px rgba(255,255,255,0.07),
      0 0 0 6px #1a1815, 0 0 0 7px var(--teal-dim),
      0 0 22px var(--teal-dim);
  }
  .console-node{
    position:absolute; top:50%; left:50%;
    width:60px; height:60px; margin:-30px 0 0 -30px;
    transform: rotate(var(--a)) translate(114px) rotate(calc(-1 * var(--a)));
    border-radius:50%;
    background: radial-gradient(circle at 30% 28%, #33302a, #1c1a15 75%);
    border:1px solid #4a4436;
    box-shadow: 0 4px 8px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1px;
    color:var(--cream); font-family:'IBM Plex Mono', monospace;
    font-size:7.5px; letter-spacing:0.4px; text-transform:uppercase;
    cursor:pointer;
  }
  .console-node .node-ico{ font-size:15px; line-height:1; margin-bottom:1px; filter:grayscale(0.15); }
  .node-led{
    position:absolute; top:5px; right:5px; width:6px; height:6px; border-radius:50%;
    background:var(--muted); transition:background 0.3s, box-shadow 0.3s;
  }
  .node-led.ok{ background:var(--teal); box-shadow:0 0 6px var(--teal-dim); }
  .node-led.warn{ background:var(--amber); box-shadow:0 0 6px var(--amber-dim); }
  .node-led.off{ background:var(--red); box-shadow:0 0 6px var(--red-dim); }

  .scope-toggle{
    display:flex; gap:6px; margin-bottom:12px;
  }
  .scope-toggle button{
    flex:1; padding:8px 6px; font-size:10.5px;
    background:var(--ink); border:1px solid #3a352c; box-shadow:none;
  }
  .scope-toggle button.active{
    background:linear-gradient(180deg, var(--teal-dim), #1c3d37);
    border-color:var(--teal-dim); color:var(--cream);
  }

  .compass-wrap{display:flex; align-items:center; gap:18px; margin-bottom:12px;}
  .compass-circle{
    width:130px; height:130px; min-width:130px; border-radius:50%;
    position:relative; background:var(--ink);
    box-shadow:inset 0 2px 8px rgba(0,0,0,0.6), 0 0 0 1px #3a352c;
  }
  .dial{position:absolute; inset:0; transition:transform 0.2s linear;}
  .tick{position:absolute; font-size:10px; color:var(--muted); font-weight:600;}
  .tick.n{top:6px; left:50%; transform:translateX(-50%); color:var(--amber);}
  .tick.e{right:7px; top:50%; transform:translateY(-50%);}
  .tick.s{bottom:6px; left:50%; transform:translateX(-50%);}
  .tick.o{left:7px; top:50%; transform:translateY(-50%);}
  .needle{
    position:absolute; left:50%; top:50%; width:4px; height:46px;
    margin-left:-2px; margin-top:-46px; transform-origin:50% 100%;
    background:linear-gradient(var(--teal), rgba(74,155,142,0));
    border-radius:3px; transition:transform 0.2s linear, opacity 0.3s;
  }
  .needle::after{
    content:''; position:absolute; top:-7px; left:50%; transform:translateX(-50%);
    border-left:6px solid transparent; border-right:6px solid transparent;
    border-bottom:11px solid var(--teal);
  }
  .needle.arrived{opacity:0.25;}
  .you-dot{
    position:absolute; left:50%; top:50%; width:8px; height:8px; border-radius:50%;
    background:var(--amber); margin-left:-4px; margin-top:-4px; box-shadow:0 0 8px var(--amber-dim);
  }
  .compass-info{flex:1; min-width:0;}
  .compass-info .live{font-size:22px; font-weight:600; color:var(--amber);}
  .compass-info .live .unit{font-size:11px; color:var(--muted); font-weight:400;}
  .compass-info .target{font-size:12px; color:var(--cream); margin-top:6px; line-height:1.5;}
  .compass-info .target b{color:var(--teal);}

  .compass-btns{display:flex; gap:8px; margin-top:4px;}
  .compass-btns button{flex:1;}
  .btn-secondary{
    background:linear-gradient(180deg, #2a2620, #221f1a) !important;
    color:var(--muted) !important;
  }

  .speed-row{margin-bottom:12px;}
  .speed-row .head{display:flex; justify-content:space-between; align-items:baseline; margin-bottom:2px;}
  .speed-row .head .k{font-size:9.5px; color:var(--muted); letter-spacing:1px; text-transform:uppercase;}
  .speed-row .head .v{font-size:16px; color:var(--cream); font-weight:600;}
  .speed-row .head .v .unit{font-size:10px; color:var(--muted); font-weight:400; margin-left:3px;}

  .radar{
    width:34px; height:34px; border-radius:50%;
    border:1px solid #4a4436;
    position:relative;
    overflow:hidden;
    background:var(--ink);
    flex-shrink:0;
  }
  .radar .sweep{
    position:absolute; top:0; left:50%; width:50%; height:50%;
    transform-origin:0% 100%;
    background:conic-gradient(from 0deg, var(--teal) 0deg, transparent 60deg);
    animation:spin 1.6s linear infinite;
    opacity:0;
  }
  .radar.active .sweep{opacity:0.85;}
  @keyframes spin{ to{ transform:rotate(360deg); } }

  footer{
    text-align:center; font-size:9.5px; color:var(--muted); margin-top:22px; letter-spacing:0.5px;
  }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div>
      <h1>Panel de Señal</h1>
      <div class="sub">Monitor de conectividad · en vivo</div>
    </div>
    <div class="clock" id="clock">--:--:--</div>
  </header>

  <!-- CONSOLA CENTRAL -->
  <div class="panel console-panel">
    <div class="panel-head">
      <div class="panel-title">Consola Central</div>
    </div>

    <div class="console-circle">
      <div class="console-ring"></div>

      <button class="console-power" id="console-power">INICIAR<br>TODO</button>

      <button class="console-node" id="node-red" style="--a:-90deg;" title="Red">
        <span class="node-led" id="led-red"></span>
        <span class="node-ico">📶</span>
        <span class="node-txt">Red</span>
      </button>
      <button class="console-node" id="node-compass" style="--a:-30deg;" title="Brújula">
        <span class="node-led" id="led-compass"></span>
        <span class="node-ico">🧭</span>
        <span class="node-txt">Brújula</span>
      </button>
      <button class="console-node" id="node-speed" style="--a:30deg;" title="Velocidad">
        <span class="node-led" id="led-speed"></span>
        <span class="node-ico">⚡</span>
        <span class="node-txt">Vel.</span>
      </button>
      <button class="console-node" id="node-bt" style="--a:90deg;" title="Bluetooth">
        <span class="node-led" id="led-bt"></span>
        <span class="node-ico">🔷</span>
        <span class="node-txt">BT</span>
      </button>
      <button class="console-node" id="node-batt" style="--a:150deg;" title="Batería">
        <span class="node-led" id="led-batt"></span>
        <span class="node-ico">🔋</span>
        <span class="node-txt">Batería</span>
      </button>
      <button class="console-node" id="node-em" style="--a:210deg;" title="Electromagnético">
        <span class="node-led" id="led-em"></span>
        <span class="node-ico">🧲</span>
        <span class="node-txt">EM</span>
      </button>
    </div>

    <div class="note" id="console-note">Tocá un nodo para ir directo a ese sensor y activarlo. El botón central enciende todo lo que se puede iniciar sin elegir nada a mano — Bluetooth siempre te va a pedir elegir el dispositivo aparte.</div>
  </div>

  <!-- PERMISOS -->
  <div class="panel" id="perm-panel">
    <div class="panel-head">
      <div class="panel-title">Permisos del equipo</div>
      <span class="status-dot idle" id="perm-dot"></span>
    </div>
    <div class="note" id="perm-note">Esta app necesita acceso a tu ubicación y a la orientación del teléfono para la brújula de señal. Bluetooth se pide aparte, cuando busques un dispositivo. Nada se envía a ningún servidor: todo queda en tu teléfono.</div>
    <div class="metrics" style="margin-top:10px;">
      <div class="metric"><div class="v" id="diag-protocol" style="font-size:11px;">—</div><div class="k">protocolo</div></div>
      <div class="metric"><div class="v" id="diag-secure" style="font-size:11px;">—</div><div class="k">contexto seguro</div></div>
      <div class="metric"><div class="v" id="diag-geo" style="font-size:11px;">—</div><div class="k">API geo</div></div>
    </div>
    <button id="perm-btn" style="margin-top:10px; width:100%;">Dar permisos ahora</button>
  </div>

  <!-- RED (WIFI / DATOS) -->
  <div class="panel" id="panel-net">
    <div class="panel-head">
      <div class="panel-title"><span class="idx">01</span>Red — Wifi / Datos</div>
      <span class="status-dot idle" id="net-dot"></span>
    </div>

    <div class="gauge-row">
      <div class="bars" id="net-bars">
        <div class="b"></div><div class="b"></div><div class="b"></div><div class="b"></div><div class="b"></div>
      </div>
      <div class="readout">
        <div class="big" id="net-type">—</div>
        <div class="lbl">tipo de conexión</div>
      </div>
    </div>

    <div class="metrics">
      <div class="metric"><div class="v" id="net-downlink">—</div><div class="k">Mbps est.</div></div>
      <div class="metric"><div class="v" id="net-rtt">—</div><div class="k">RTT ms</div></div>
      <div class="metric"><div class="v" id="net-save">—</div><div class="k">ahorro datos</div></div>
    </div>

    <div class="note" id="net-note">Detectando compatibilidad del navegador…</div>
  </div>

  <!-- BRÚJULA DE SEÑAL (GPS) -->
  <div class="panel" id="panel-compass">
    <div class="panel-head">
      <div class="panel-title"><span class="idx">02</span>Brújula de Señal</div>
      <span class="status-dot idle" id="compass-dot"></span>
    </div>

    <div class="scope-toggle">
      <button class="active" id="scope-movil">Datos móviles</button>
      <button id="scope-wifi">Wifi</button>
    </div>

    <div class="compass-wrap">
      <div class="compass-circle">
        <div class="dial" id="compass-dial">
          <span class="tick n">N</span>
          <span class="tick e">E</span>
          <span class="tick s">S</span>
          <span class="tick o">O</span>
        </div>
        <div class="needle" id="compass-needle"></div>
        <div class="you-dot"></div>
      </div>
      <div class="compass-info">
        <div class="live" id="compass-live">—<span class="unit">Mbps ahora</span></div>
        <div class="target" id="compass-target">Presioná «Iniciar mapeo» y caminá despacio por la casa.</div>
        <div class="target" id="compass-accuracy" style="margin-top:4px; font-size:10.5px; color:var(--muted);"></div>
      </div>
    </div>

    <div class="compass-btns" id="router-btns" style="display:none;">
      <button id="mark-router-btn">📍 Marcar router acá</button>
      <button id="forget-router-btn" class="btn-secondary">Olvidar</button>
    </div>

    <div class="compass-btns">
      <button id="compass-start">Iniciar mapeo</button>
      <button id="compass-reset" class="btn-secondary">Reiniciar</button>
    </div>

    <div class="note" id="compass-note">Elegí arriba qué red estás usando ahora mismo. La app mide tu velocidad real cada pocos segundos en cada punto y la flecha señala hacia el mejor lugar detectado en este recorrido. Necesita permiso de ubicación y, en iPhone, de orientación. Consume algo de datos si estás midiendo datos móviles.</div>
  </div>

  <!-- TEST DE VELOCIDAD REAL -->
  <div class="panel" id="panel-speed">
    <div class="panel-head">
      <div class="panel-title"><span class="idx">03</span>Test de Velocidad Real</div>
      <span class="status-dot idle" id="speed-dot"></span>
    </div>

    <div class="speed-row">
      <div class="head"><span class="k">Bajada <span id="speed-down-phase" style="color:var(--teal);"></span></span><span class="v" id="speed-down">—<span class="unit">Mbps</span></span></div>
      <div class="progress"><div class="fill" id="speed-down-fill"></div></div>
    </div>

    <div class="speed-row">
      <div class="head"><span class="k">Subida <span id="speed-up-phase" style="color:var(--amber);"></span></span><span class="v" id="speed-up">—<span class="unit">Mbps</span></span></div>
      <div class="progress"><div class="fill up" id="speed-up-fill"></div></div>
    </div>

    <div class="metrics">
      <div class="metric"><div class="v" id="speed-datamb">0</div><div class="k">MB transferidos</div></div>
      <div class="metric"><div class="v" id="speed-conns">4</div><div class="k">conexiones paralelas</div></div>
      <div class="metric"><div class="v" id="speed-elapsed">0s</div><div class="k">tiempo</div></div>
    </div>

    <button id="speed-btn">Iniciar test de velocidad (10s + 10s)</button>

    <div class="note" id="speed-note">Mide 10 segundos de bajada y 10 de subida, transfiriendo datos reales con 4 conexiones simultáneas (igual que Speedtest/fast.com), descartando el arranque inicial para dar un número estable. El consumo de datos depende de tu velocidad: puede ir de unos MB a 100+ MB en conexiones muy rápidas.</div>
  </div>

  <!-- BLUETOOTH -->
  <div class="panel" id="panel-bt">
    <div class="panel-head">
      <div class="panel-title"><span class="idx">04</span>Bluetooth</div>
      <span class="status-dot idle" id="bt-dot"></span>
    </div>

    <div class="gauge-row">
      <div class="radar" id="bt-radar"><div class="sweep"></div></div>
      <div class="readout">
        <div class="big" id="bt-status">Sin escanear</div>
        <div class="lbl">estado</div>
      </div>
    </div>

    <button id="bt-scan-btn">Buscar dispositivo cercano</button>
    <button id="bt-watch-btn" style="margin-left:8px; display:none;">Ver señal en vivo (RSSI)</button>

    <div class="device-list" id="bt-devices"></div>

    <div class="note" id="bt-note">Bluetooth vía navegador requiere permiso explícito por dispositivo y solo funciona en Chrome/Edge (Android o escritorio). No hay escaneo pasivo por seguridad.</div>
  </div>

  <!-- BATERÍA DEL EQUIPO -->
  <div class="panel" id="panel-batt">
    <div class="panel-head">
      <div class="panel-title"><span class="idx">05</span>Batería del Equipo</div>
      <span class="status-dot idle" id="batt-dot"></span>
    </div>

    <div class="gauge-row">
      <div class="progress" style="flex:1; height:22px; border-radius:5px;">
        <div class="fill" id="batt-fill" style="height:100%; border-radius:5px;"></div>
      </div>
      <div class="readout" style="flex:0 0 auto; min-width:70px; text-align:center;">
        <div class="big" id="batt-level">—</div>
        <div class="lbl">nivel</div>
      </div>
    </div>

    <div class="metrics">
      <div class="metric"><div class="v" id="batt-status">—</div><div class="k">estado</div></div>
      <div class="metric"><div class="v" id="batt-time">—</div><div class="k">tiempo est.</div></div>
    </div>

    <div class="note" id="batt-note">Detectando compatibilidad…</div>
  </div>

  <!-- DETECTOR ELECTROMAGNÉTICO -->
  <div class="panel" id="panel-em">
    <div class="panel-head">
      <div class="panel-title"><span class="idx">06</span>Detector Electromagnético</div>
      <span class="status-dot idle" id="em-dot"></span>
    </div>

    <div class="gauge-row">
      <div class="progress" style="flex:1; height:22px; border-radius:5px;">
        <div class="fill" id="em-fill" style="height:100%; border-radius:5px;"></div>
      </div>
      <div class="readout" style="flex:0 0 auto; min-width:80px; text-align:center;">
        <div class="big" id="em-value">—</div>
        <div class="lbl">µT</div>
      </div>
    </div>

    <div class="metrics">
      <div class="metric"><div class="v" id="em-baseline">—</div><div class="k">línea base µT</div></div>
      <div class="metric"><div class="v" id="em-deviation">—</div><div class="k">desvío</div></div>
    </div>

    <button id="em-start-btn">Iniciar detector</button>

    <div class="note" id="em-note">Mide el campo magnético crudo del teléfono. El campo de la Tierra ronda 25-65 µT y es bastante estable; si un metal grande, electrónica o un cable de alta tensión distorsiona la lectura, te avisa. Es una señal aproximada, no localiza el objeto. Solo funciona en Chrome para Android (Generic Sensor API).</div>
  </div>

  <footer>
    Los navegadores no exponen dBm real de wifi/datos móviles — estos valores son estimaciones basadas en velocidad y latencia reportadas por el sistema.
  </footer>

</div>

<script>
// ---------- RELOJ ----------
function tickClock(){
  const d = new Date();
  document.getElementById('clock').textContent = d.toLocaleTimeString('es-AR', {hour12:false});
}
setInterval(tickClock, 1000); tickClock();

// ---------- RED (Network Information API) ----------
const netDot = document.getElementById('net-dot');
const netBars = document.querySelectorAll('#net-bars .b');
const netType = document.getElementById('net-type');
const netDownlink = document.getElementById('net-downlink');
const netRtt = document.getElementById('net-rtt');
const netSave = document.getElementById('net-save');
const netNote = document.getElementById('net-note');

function classForQuality(level){ // 0-5
  if(level >= 4) return '';
  if(level >= 2) return 'warn';
  return 'weak';
}

function renderBars(level, quality){
  netBars.forEach((b, i) => {
    b.classList.remove('lit','warn','weak');
    if(i < level){
      b.classList.add('lit');
      if(quality) b.classList.add(quality);
    }
  });
}

function updateNetwork(){
  if(!navigator.onLine){
    netDot.className = 'status-dot off';
    netType.textContent = 'SIN CONEXIÓN';
    renderBars(0);
    netDownlink.textContent = '—';
    netRtt.textContent = '—';
    netSave.textContent = '—';
    netNote.innerHTML = '<b>Offline.</b> El dispositivo no reporta ninguna red activa.';
    return;
  }

  const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;

  if(!conn){
    netDot.className = 'status-dot ok';
    netType.textContent = 'CONECTADO';
    renderBars(3, 'warn');
    netDownlink.textContent = '—';
    netRtt.textContent = '—';
    netSave.textContent = '—';
    netNote.innerHTML = 'Tu navegador (probablemente Safari/iOS) no expone detalles de red. Solo se sabe que hay conexión activa.';
    return;
  }

  const type = conn.type; // wifi, cellular, none, unknown...
  const effectiveType = conn.effectiveType; // slow-2g, 2g, 3g, 4g
  const downlink = conn.downlink; // Mbps estimado
  const rtt = conn.rtt; // ms
  const saveData = conn.saveData;

  let label = type ? type.toUpperCase() : (effectiveType ? effectiveType.toUpperCase() : 'DESCONOCIDO');
  netType.textContent = label;

  // nivel de barras en base a effectiveType + downlink
  let level = 3, quality = 'warn';
  if(effectiveType === '4g' || downlink >= 5){ level = 5; quality = ''; }
  else if(effectiveType === '3g' || downlink >= 1.5){ level = 3; quality = 'warn'; }
  else if(effectiveType === '2g' || downlink >= 0.4){ level = 2; quality = 'weak'; }
  else if(effectiveType === 'slow-2g'){ level = 1; quality = 'weak'; }

  renderBars(level, quality);
  netDot.className = 'status-dot ' + (level >= 4 ? 'ok' : level >= 2 ? 'warn' : 'off');

  netDownlink.textContent = downlink !== undefined ? downlink.toFixed(1) : '—';
  netRtt.textContent = rtt !== undefined ? Math.round(rtt) : '—';
  netSave.textContent = saveData ? 'ON' : 'OFF';

  netNote.innerHTML = `Fuente: Network Information API. <b>${effectiveType ? effectiveType.toUpperCase() : '—'}</b> efectivo. Estos valores son estimaciones del navegador, no dBm real.`;
}

if(navigator.connection){
  navigator.connection.addEventListener('change', updateNetwork);
}
window.addEventListener('online', updateNetwork);
window.addEventListener('offline', updateNetwork);
updateNetwork();
setInterval(updateNetwork, 4000);

// ---------- BRÚJULA DE SEÑAL (GPS) ----------
const compassDot = document.getElementById('compass-dot');
const compassLive = document.getElementById('compass-live');
const compassTarget = document.getElementById('compass-target');
const compassNote = document.getElementById('compass-note');
const compassStartBtn = document.getElementById('compass-start');
const compassResetBtn = document.getElementById('compass-reset');
const compassDial = document.getElementById('compass-dial');
const compassNeedle = document.getElementById('compass-needle');
const scopeMovilBtn = document.getElementById('scope-movil');
const scopeWifiBtn = document.getElementById('scope-wifi');

const mapping = {
  movil: { log: [], best: null },
  wifi: { log: [], best: null }
};
let activeScope = 'movil';
let compassActive = false;
let currentPos = null;
let currentHeading = 0;
let headingKnown = false;
let watchId = null;
let sampleTimer = null;
let orientationHandler = null;

// Ubicación real del router, marcada a mano una vez por el usuario. Se guarda
// en localStorage porque esta app corre como sitio propio (Vercel/GitHub Pages),
// no como vista previa embebida, así que el almacenamiento del navegador funciona normal.
let routerLocation = null;
try{
  const savedRouter = localStorage.getItem('ms_router_location');
  if(savedRouter) routerLocation = JSON.parse(savedRouter);
}catch(e){ /* localStorage no disponible, sigue sin guardado persistente */ }

const routerBtnsWrap = document.getElementById('router-btns');
const markRouterBtn = document.getElementById('mark-router-btn');
const forgetRouterBtn = document.getElementById('forget-router-btn');

function toRad(d){ return d * Math.PI / 180; }
function toDeg(r){ return r * 180 / Math.PI; }

function bearing(lat1, lon1, lat2, lon2){
  const dLon = toRad(lon2 - lon1);
  const y = Math.sin(dLon) * Math.cos(toRad(lat2));
  const x = Math.cos(toRad(lat1)) * Math.sin(toRad(lat2)) - Math.sin(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.cos(dLon);
  return (toDeg(Math.atan2(y, x)) + 360) % 360;
}

function distan